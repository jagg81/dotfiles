# Not needed, .profile was removed
#[[ -s "$HOME/.profile" ]] && source "$HOME/.profile" # Load the default .profile

ssh-add -l > /dev/null
if [[ $? -ne 0 ]]; then
    ssh-add "$HOME/.ssh/id_ed25519"
fi

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
	. "$HOME/.bashrc"
    fi
fi

