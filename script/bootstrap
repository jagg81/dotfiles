#!/bin/bash
#
# bootstrap installs things.

set -e

CONFIG_DIR="$HOME/.dotfiles"

BOLD='\033[1m'
GREEN='\033[32m'
YELLOW='\033[33m'
CYAN='\033[36m'
DIM='\033[2m'
RESET='\033[0m'

LINKED=()
COPIED=()
BACKED_UP=()
REPLACED=()
SKIPPED=()
SECTIONS_SKIPPED=()

confirm() {
    echo ""
    printf "${BOLD}${CYAN}▶ Install $1?${RESET} [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]]
}

ensure_dir() {
    local dir
    dir="$(dirname "$1")"
    if [ ! -d "$dir" ]; then
        mkdir -p "$dir"
        printf "  ${DIM}created dir: $dir${RESET}\n"
    fi
}

link_config() {
    local src="$CONFIG_DIR/$1"
    local dest="$HOME/$2"

    ensure_dir "$dest"

    if [ -L "$dest" ]; then
        if [ "$(readlink "$dest")" = "$src" ]; then
            printf "  ${DIM}already linked: $dest${RESET}\n"
            SKIPPED+=("$dest")
        else
            printf "  ${YELLOW}stale symlink, replacing:${RESET} $dest\n"
            rm "$dest"
            ln -s "$src" "$dest"
            REPLACED+=("$dest")
        fi
    elif [ -e "$dest" ]; then
        mv "$dest" "$dest.bk"
        printf "  ${YELLOW}backed up:${RESET} $dest.bk\n"
        BACKED_UP+=("$dest.bk")
        ln -s "$src" "$dest"
        printf "  ${GREEN}linked:${RESET} $dest\n"
        LINKED+=("$dest")
    else
        ln -s "$src" "$dest"
        printf "  ${GREEN}linked:${RESET} $dest\n"
        LINKED+=("$dest")
    fi
}

copy_config() {
    local src="$CONFIG_DIR/$1"
    local dest="$HOME/$2"

    ensure_dir "$dest"

    if [ -e "$dest" ]; then
        mv "$dest" "$dest.bk"
        printf "  ${YELLOW}backed up:${RESET} $dest.bk\n"
        BACKED_UP+=("$dest.bk")
    fi
    cp -r "$src" "$dest"
    printf "  ${GREEN}copied:${RESET} $dest\n"
    COPIED+=("$dest")
}

# -----------------------------------------------

echo ""
printf "${BOLD}dotfiles bootstrap${RESET}\n"
printf "${DIM}Config dir: $CONFIG_DIR${RESET}\n"

if confirm "Bash"; then
    link_config 'bash/bash_profile.symlink' '.bash_profile'
    link_config 'bash/bashrc.symlink' '.bashrc'
    link_config 'bash/aliases.symlink' '.bash_aliases'
    copy_config 'bash/localrc.copylink' '.localrc'
else
    SECTIONS_SKIPPED+=("Bash")
fi

if confirm "Vim"; then
    link_config 'vim/vim.symlink' '.vim'
    link_config 'vim/vimrc.symlink' '.vimrc'
    for dir in "$HOME/.vim/backup" "$HOME/.vim/tmp"; do
        if [ ! -d "$dir" ]; then
            mkdir -p "$dir"
            printf "  ${GREEN}created:${RESET} $dir\n"
            LINKED+=("$dir/")
        else
            printf "  ${DIM}already exists: $dir${RESET}\n"
            SKIPPED+=("$dir/")
        fi
    done
else
    SECTIONS_SKIPPED+=("Vim")
fi

if confirm "SSH"; then
    link_config 'ssh/config.symlink' '.ssh/config'
    link_config 'ssh/rc.symlink' '.ssh/rc'
else
    SECTIONS_SKIPPED+=("SSH")
fi

if confirm "tmux"; then
    link_config 'tmux/tmux.conf.symlink' '.tmux.conf'
else
    SECTIONS_SKIPPED+=("tmux")
fi

if confirm "Git"; then
    copy_config 'git/gitconfig.copylink' '.gitconfig'
else
    SECTIONS_SKIPPED+=("Git")
fi

if confirm "Irssi"; then
    copy_config 'irssi/irssi.symlink' '.irssi'
else
    SECTIONS_SKIPPED+=("Irssi")
fi

if confirm "VS Code"; then
    copy_config 'vscode/settings.json.copylink' 'Library/Application Support/Code/User/settings.json'
else
    SECTIONS_SKIPPED+=("VS Code")
fi

if confirm "Cursor"; then
    copy_config 'cursor/settings.json.copylink' 'Library/Application Support/Cursor/User/settings.json'
else
    SECTIONS_SKIPPED+=("Cursor")
fi

if confirm "Claude Code"; then
    link_config 'claude/CLAUDE.md.symlink' '.claude/CLAUDE.md'
    link_config 'claude/settings.json.symlink' '.claude/settings.json'
    link_config 'claude/statusline.sh.symlink' '.claude/statusline.sh'
    link_config 'claude/agents/code-reviewer.md.symlink' '.claude/agents/code-reviewer.md'
    link_config 'claude/skills/gh-commit-content/SKILL.md.symlink' '.claude/skills/gh-commit-content/SKILL.md'
else
    SECTIONS_SKIPPED+=("Claude Code")
fi

# -----------------------------------------------
# Summary

echo ""
printf "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
printf "${BOLD}Summary${RESET}\n"
printf "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"

if [ ${#LINKED[@]} -gt 0 ]; then
    printf "\n${GREEN}Linked (${#LINKED[@]}):${RESET}\n"
    for f in "${LINKED[@]}"; do printf "  $f\n"; done
fi

if [ ${#COPIED[@]} -gt 0 ]; then
    printf "\n${GREEN}Copied (${#COPIED[@]}):${RESET}\n"
    for f in "${COPIED[@]}"; do printf "  $f\n"; done
fi

if [ ${#REPLACED[@]} -gt 0 ]; then
    printf "\n${YELLOW}Replaced stale symlinks (${#REPLACED[@]}):${RESET}\n"
    for f in "${REPLACED[@]}"; do printf "  $f\n"; done
fi

if [ ${#BACKED_UP[@]} -gt 0 ]; then
    printf "\n${YELLOW}Backed up (${#BACKED_UP[@]}):${RESET}\n"
    for f in "${BACKED_UP[@]}"; do printf "  $f\n"; done
fi

if [ ${#SKIPPED[@]} -gt 0 ]; then
    printf "\n${DIM}Already linked (${#SKIPPED[@]}):${RESET}\n"
    for f in "${SKIPPED[@]}"; do printf "  $f\n"; done
fi

if [ ${#SECTIONS_SKIPPED[@]} -gt 0 ]; then
    printf "\n${DIM}Sections skipped: ${SECTIONS_SKIPPED[*]}${RESET}\n"
fi

echo ""
printf "${GREEN}${BOLD}Done.${RESET}\n"
